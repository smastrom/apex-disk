{
  "name": "mac-user-lens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "dev": "vite",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build --target universal-apple-darwin",
    "test": "node tests/smoke.js"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@tanstack/vue-virtual": "^3.13.19",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-store": "^2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "oxfmt": "^0.35",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "pnpm": ">=8"
  }
}
