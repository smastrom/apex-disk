{
   "name": "apex-disk",
   "version": "0.0.16",
   "private": false,
   "description": "macOS tool to easily identify and get rid of big, unused files and folders in seconds.",
   "keywords": [
      "directory-size",
      "disk-space-analyzer",
      "disk-usage-visualizer",
      "free-up-space",
      "junk-cleaner",
      "macos-utility",
      "open-source",
      "performance",
      "rust",
      "storage-cleaner",
      "system-cleaner",
      "tauri",
      "treemap",
      "vue"
   ],
   "homepage": "https://github.com/smastrom/apex-disk",
   "bugs": {
      "url": "https://github.com/smastrom/apex-disk/issues"
   },
   "license": "GPL-3.0",
   "author": {
      "name": "Simone Mastromattei",
      "email": "smastrom@proton.me",
      "url": "https://github.com/smastrom"
   },
   "repository": {
      "type": "git",
      "url": "https://github.com/smastrom/apex-disk.git"
   },
   "type": "module",
   "scripts": {
      "build": "vue-tsc --noEmit && vite build",
      "clean": "rm -rf dist",
      "clean:all": "rm -rf dist && pnpm tauri:clean",
      "dev": "vite",
      "fmt": "oxfmt --write",
      "fmt:check": "oxfmt --check",
      "headers": "scripts/add-license-headers.sh",
      "headers:check": "scripts/add-license-headers.sh --check",
      "oxlint": "oxlint",
      "oxlint:fix": "oxlint --fix",
      "prepare": "husky",
      "rust:fmt": "cargo +nightly fmt --manifest-path src-tauri/Cargo.toml",
      "rust:fmt:check": "cargo +nightly fmt --manifest-path src-tauri/Cargo.toml -- --check",
      "tauri": "tauri",
      "tauri:build": "source scripts/load-env.sh && tauri build --target universal-apple-darwin --verbose",
      "tauri:build:beta": "source scripts/load-env.sh && tauri build --target universal-apple-darwin --config src-tauri/tauri.beta.conf.json --verbose",
      "tauri:build:unsigned": "APPLE_SIGNING_IDENTITY='-' tauri build --target universal-apple-darwin",
      "tauri:clean": "cargo clean --manifest-path src-tauri/Cargo.toml && rm -rf target",
      "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
      "tauri:icons": "tauri icon ./src-tauri/icons/app-icon.png && cd ./src-tauri/icons && rm -rf android && rm -rf ios",
      "test:e2e": "wdio run e2e/wdio.conf.ts",
      "test:unit": "cargo test --manifest-path src-tauri/Cargo.toml -- --test-threads=1",
      "typecheck": "vue-tsc --noEmit"
   },
   "dependencies": {
      "@floating-ui/dom": "^1.7.6",
      "@phosphor-icons/vue": "^2.2.1",
      "@tauri-apps/api": "^2.11.0",
      "@tauri-apps/plugin-opener": "^2.5.4",
      "@tauri-apps/plugin-os": "~2.3.2",
      "@tauri-apps/plugin-store": "^2.4.3",
      "@tauri-apps/plugin-updater": "^2.10.1",
      "vite": "^8.0.11",
      "vue": "^3.5.34"
   },
   "devDependencies": {
      "@rollup/plugin-yaml": "^4.1.2",
      "@stylistic/eslint-plugin": "^5.10.0",
      "@tauri-apps/cli": "^2.11.1",
      "@types/node": "^25.6.0",
      "@vitejs/plugin-vue": "^6.0.6",
      "@wdio/cli": "^9.27.1",
      "@wdio/globals": "^9.27.1",
      "@wdio/local-runner": "^9.27.1",
      "@wdio/mocha-framework": "^9.27.1",
      "@wdio/spec-reporter": "^9.27.1",
      "bun": "^1.3.13",
      "eslint-plugin-perfectionist": "^5.9.0",
      "husky": "^9.1.7",
      "lightningcss": "^1.32.0",
      "lint-staged": "^15.5.2",
      "oxfmt": "^0.35.0",
      "oxlint": "^1.66.0",
      "typescript": "~5.6.3",
      "vue-tsc": "^2.2.12"
   },
   "lint-staged": {
      "*.{css,json,jsonc,html}": "oxfmt --write",
      "*.{js,ts,vue}": [
         "oxlint --fix",
         "oxfmt --write"
      ],
      "*.rs": "rustfmt +nightly"
   },
   "engines": {
      "node": ">=22.0.0",
      "pnpm": ">=10"
   },
   "packageManager": "pnpm@10.33.0"
}
