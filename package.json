{
  "name": "mac-user-lens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "clean": "rm -rf dist",
    "clean:all": "rm -rf dist && pnpm tauri:clean",
    "dev": "vite",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --target universal-apple-darwin",
    "tauri:icons": "tauri icon ./src-tauri/icons/app-icon.png && cd ./src-tauri/icons && rm -rf android && rm -rf ios",
    "tauri:clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "test": "node tests/index.js"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@tanstack/vue-virtual": "^3.13.19",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "oxfmt": "^0.35.0",
    "typescript": "~5.6.3",
    "vite": "^6.4.1",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "pnpm": ">=10"
  }
}
