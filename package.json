{
   "name": "apex-disk",
   "version": "0.0.9",
   "private": false,
   "description": "macOS tool to easily identify and get rid of big, unused files and folders in seconds.",
   "keywords": [
      "directory-size",
      "disk-space-analyzer",
      "disk-usage-visualizer",
      "free-up-space",
      "junk-cleaner",
      "macos-utility",
      "open-source",
      "performance",
      "rust",
      "storage-cleaner",
      "system-cleaner",
      "tauri",
      "treemap",
      "vue"
   ],
   "homepage": "https://github.com/smastrom/apex-disk",
   "bugs": {
      "url": "https://github.com/smastrom/apex-disk/issues"
   },
   "license": "GPL-3.0",
   "author": {
      "name": "Simone Mastromattei",
      "email": "smastrom@proton.me",
      "url": "https://github.com/smastrom"
   },
   "repository": {
      "type": "git",
      "url": "https://github.com/smastrom/apex-disk.git"
   },
   "type": "module",
   "scripts": {
      "build": "vue-tsc --noEmit && vite build",
      "clean": "rm -rf dist",
      "clean:all": "rm -rf dist && pnpm tauri:clean",
      "dev": "vite",
      "fmt": "oxfmt --write",
      "fmt:check": "oxfmt --check",
      "prepare": "husky",
      "tauri": "tauri",
      "tauri:build": "source scripts/load-env.sh && tauri build --target universal-apple-darwin --verbose",
      "tauri:build:unsigned": "APPLE_SIGNING_IDENTITY='-' tauri build --target universal-apple-darwin",
      "tauri:clean": "cargo clean --manifest-path src-tauri/Cargo.toml && rm -rf target",
      "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
      "tauri:icons": "tauri icon ./src-tauri/icons/app-icon.png && cd ./src-tauri/icons && rm -rf android && rm -rf ios",
      "test:e2e": "wdio run e2e/wdio.conf.ts",
      "test:unit": "cargo test --manifest-path src-tauri/Cargo.toml -- --test-threads=1"
   },
   "dependencies": {
      "@phosphor-icons/vue": "^2.2.1",
      "@tauri-apps/api": "^2.10.1",
      "@tauri-apps/plugin-opener": "^2.5.3",
      "@tauri-apps/plugin-os": "~2.3.2",
      "@tauri-apps/plugin-store": "^2.4.2",
      "vue": "^3.5.29"
   },
   "devDependencies": {
      "@tauri-apps/cli": "^2.10.1",
      "@types/node": "^25.3.5",
      "@vitejs/plugin-vue": "^6.0.4",
      "@wdio/cli": "^9.24.0",
      "@wdio/globals": "^9.23.0",
      "@wdio/local-runner": "^9.24.0",
      "@wdio/mocha-framework": "^9.24.0",
      "@wdio/spec-reporter": "^9.24.0",
      "husky": "^9.1.7",
      "lint-staged": "^15.5.2",
      "oxfmt": "^0.35.0",
      "tsx": "^4.21.0",
      "typescript": "~5.6.3",
      "vite": "npm:rolldown-vite@^7.3.1",
      "vue-tsc": "^2.2.12"
   },
   "lint-staged": {
      "*.{css,js,json,jsonc,html,ts,vue}": "oxfmt --write",
      "*.rs": "rustfmt"
   },
   "engines": {
      "node": ">=22.0.0",
      "pnpm": ">=10"
   },
   "packageManager": "pnpm@10.30.0",
   "pnpm": {
      "overrides": {
         "vite": "npm:rolldown-vite@latest"
      }
   }
}
