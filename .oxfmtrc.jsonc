{
   "$schema": "./node_modules/oxfmt/configuration_schema.json",
   "printWidth": 100,
   "semi": false,
   "singleQuote": true,
   "tabWidth": 3,
   "trailingComma": "es5",
   "useTabs": false,
   "ignorePatterns": ["node_modules/**", "dist/**", "target/**", "reference/temp/**"],
   "sortPackageJson": {
      "sortScripts": true,
   },
}
