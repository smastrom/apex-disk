{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "macOS Disk Lens",
   "version": "0.1.0",
   "identifier": "com.smastrom.macos-disk-lens",
   "build": {
      "beforeDevCommand": "pnpm dev",
      "devUrl": "http://localhost:1420",
      "beforeBuildCommand": "pnpm build",
      "frontendDist": "../dist"
   },
   "app": {
      "windows": [
         {
            "title": "macOS Disk Lens",
            "width": 800,
            "height": 600
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
         "icons/32x32.png",
         "icons/128x128.png",
         "icons/128x128@2x.png",
         "icons/icon.icns",
         "icons/icon.ico"
      ]
   }
}
