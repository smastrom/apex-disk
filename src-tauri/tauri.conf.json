{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "Mac User Lens",
   "version": "0.0.8",
   "identifier": "com.smastrom.mac-user-lens",
   "build": {
      "beforeDevCommand": "pnpm dev",
      "devUrl": "http://localhost:1420",
      "beforeBuildCommand": "pnpm build",
      "frontendDist": "../dist"
   },
   "app": {
      "windows": [
         {
            "title": "Mac User Lens",
            "hiddenTitle": true,
            "width": 425,
            "height": 825,
            "resizable": false,
            "fullscreen": false,
            "titleBarStyle": "Overlay",
            "center": true
         }
      ],
      "security": { "csp": null }
   },
   "bundle": {
      "active": true,
      "targets": ["dmg"],
      "createUpdaterArtifacts": true,
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
      "category": "Utility",
      "shortDescription": "Disk usage analyzer for macOS",
      "longDescription": "Identify and remove large, unused files and folders on your Mac.",
      "macOS": {
         "minimumSystemVersion": "10.15",
         "hardenedRuntime": true,
         "entitlements": "Entitlements.plist"
      }
   },
   "plugins": {
      "updater": {
         "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyRUY0RERBQzc0RjhDQkYKUldTL2pFL0gyazN2OGttZHQvV2piNnBwc0kveDBMb0dNREJDNWl5V0tmZEVYUkdHa3J6cm9wOTcK",
         "endpoints": [
            "https://github.com/smastrom/mac-user-lens/releases/latest/download/latest.json"
         ]
      }
   }
}
