{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "ApexDisk",
   "version": "0.0.9",
   "identifier": "com.smastrom.apex-disk",
   "build": {
      "beforeDevCommand": "pnpm dev",
      "devUrl": "http://localhost:1420",
      "beforeBuildCommand": "pnpm build",
      "frontendDist": "../dist"
   },
   "app": {
      "windows": [
         {
            "title": "ApexDisk",
            "hiddenTitle": true,
            "width": 425,
            "height": 825,
            "resizable": false,
            "fullscreen": false,
            "titleBarStyle": "Overlay",
            "center": true
         }
      ],
      "security": { "csp": null }
   },
   "bundle": {
      "active": true,
      "targets": ["app", "dmg"],
      "createUpdaterArtifacts": false,
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
      "category": "Utility",
      "shortDescription": "Disk usage analyzer for macOS",
      "longDescription": "Identify and remove large, unused files and folders on your Mac.",
      "macOS": {
         "minimumSystemVersion": "10.15",
         "hardenedRuntime": true,
         "entitlements": "Entitlements.plist"
      }
   }
}
